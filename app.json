{
  "expo": {
    "name": "PENTOL - Pencatatan Online",
    "slug": "pentol-harvest-management",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "pentol",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.sawitmanunggal.pentol",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-sqlite",
      "expo-localization",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "34.0.0",
            "kotlinVersion": "2.0.21",
            "multiDexEnabled": true,
            "enableShrinkResourcesInReleaseBuilds": false,
            "enableProguardInReleaseBuilds": false,
            "gradleProperties": {
              "org.gradle.jvmargs": "-Xmx4096m -XX:MaxMetaspaceSize=512m",
              "org.gradle.daemon": "false",
              "org.gradle.parallel": "true"
            },
            "extraGradleArguments": [
              "-Pandroid.enableDexingArtifactTransform.desugaring=false",
              "-Pandroid.kotlin.suppressExpectActualClasses=true"
            ],
            "extraGradleProperties": {
              "android.suppressUnsupportedCompileSdk": "35"
            },
            "packagingOptions": {
              "pickFirst": [
                "**/libc++_shared.so",
                "**/libreactnative.so",
                "**/libfbjni.so",
                "**/libreact_native_modules.so",
                "**/libhermes.so",
                "**/libjscexecutor.so",
                "**/libfolly_json.so",
                "**/libfolly_runtime.so",
                "**/libglog.so",
                "**/libyoga.so",
                "**/libcrypto.so",
                "**/libssl.so",
                "**/libtrae.so",
                "**/libliteavsdk.so"
              ],
              "exclude": [
                "META-INF/*.kotlin_module",
                "META-INF/DEPENDENCIES",
                "META-INF/LICENSE",
                "META-INF/LICENSE.txt",
                "META-INF/license.txt",
                "META-INF/NOTICE",
                "META-INF/NOTICE.txt",
                "META-INF/notice.txt",
                "META-INF/ASL2.0",
                "**/libjsc.so"
              ],
              "doNotStrip": [
                "**/libtrae.so",
                "**/libliteavsdk.so"
              ]
            },
            "enableMinifyInReleaseBuilds": false
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "neonAuthUrl": "https://ep-morning-shadow-a1p4v4nw.neonauth.ap-southeast-1.aws.neon.tech/neondb/auth",
      "eas": {
        "projectId": "79e9f14f-8c9a-4111-b59c-a607cc8c8d88"
      }
    },
    "owner": "koncoweb"
  }
}
